<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #eee; border-radius: 8px; }
        .header { border-bottom: 2px solid #00d09c; padding-bottom: 10px; margin-bottom: 20px; }
        .product-name { color: #00d09c; font-weight: bold; font-size: 24px; }
        .week { color: #666; font-size: 14px; }
        .theme { margin-bottom: 25px; padding: 15px; background: #f9f9f9; border-left: 4px solid #00d09c; border-radius: 4px; }
        .theme-name { font-weight: bold; font-size: 18px; margin-bottom: 5px; color: #1a1a1a; }
        .theme-summary { font-size: 14px; margin-bottom: 10px; }
        .stats { font-size: 12px; color: #888; margin-top: 5px; }
        .button { display: inline-block; padding: 12px 24px; background-color: #00d09c; color: white; text-decoration: none; border-radius: 6px; font-weight: bold; margin-top: 20px; }
        .footer { margin-top: 30px; font-size: 12px; color: #999; text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="product-name">{{ summary.product_name }} — Weekly Pulse</div>
            <div class="week">Period: {{ summary.iso_week }} ({{ summary.data_window }})</div>
        </div>

        <p>Hello Team,</p>
        <p>Here are the top themes from <strong>{{ summary.total_reviews_analyzed }}</strong> reviews analyzed this week.</p>

        {% for theme in summary.top_themes %}
        <div class="theme">
            <div class="theme-name">{{ loop.index }}. {{ theme.name }}</div>
            <div class="theme-summary">{{ theme.summary }}</div>
            <div class="stats">{{ theme.review_count }} reviews matched this theme.</div>
        </div>
        {% endfor %}

        <a href="{{ doc_link }}" class="button">Read Full Report in Google Docs</a>

        <div class="footer">
            Generated automatically by GrowwReviewAnalyzerMCP<br>
            Cost of this run: ${{ "%.4f"|format(summary.metrics.get('total_cost', 0.0) or 0.0) }}
        </div>
    </div>
</body>
</html>
